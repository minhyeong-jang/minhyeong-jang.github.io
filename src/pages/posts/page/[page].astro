---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PostRow from '../../../components/blog/PostRow.astro';
import TagChips from '../../../components/blog/TagChips.astro';
import Pager from '../../../components/blog/Pager.astro';
import { getSortedPosts, getAllTags } from '../../../lib/posts';

export async function getStaticPaths() {
  const allPosts = await getSortedPosts();
  const PER_PAGE = 15;
  const totalPages = Math.ceil(allPosts.length / PER_PAGE);
  return Array.from({ length: totalPages - 1 }, (_, i) => ({
    params: { page: String(i + 2) },
  }));
}

const PER_PAGE = 15;
const page = Number(Astro.params.page);
const allPosts = await getSortedPosts();
const tags = getAllTags(allPosts);
const totalPages = Math.ceil(allPosts.length / PER_PAGE);
const posts = allPosts.slice((page - 1) * PER_PAGE, page * PER_PAGE);

const byYear = new Map<string, typeof posts>();
posts.forEach(p => {
  const y = String(p.data.date.getFullYear());
  if (!byYear.has(y)) byYear.set(y, []);
  byYear.get(y)!.push(p);
});
---
<BaseLayout title={`Blog — Page ${page}`}>
  <main class="page page-blog">
    <header class="blog-header">
      <div class="blog-header-mono">// posts/index.tsx</div>
      <h1 class="blog-h">Writing</h1>
      <p class="blog-sub">
        프론트엔드, 도구, 그리고 가끔 회고. <span class="blog-sub-mono">{allPosts.length} posts · 2016—2026</span>
      </p>
    </header>

    <TagChips tags={tags} activeTag={null} totalCount={allPosts.length} />

    <div class="post-timeline">
      {[...byYear.entries()].map(([year, yearPosts]) => (
        <section class="post-year">
          <div class="post-year-mark">{year}</div>
          <ul class="post-year-list">
            {yearPosts.map(p => <PostRow post={p} />)}
          </ul>
        </section>
      ))}
    </div>

    <Pager currentPage={page} totalPages={totalPages} baseUrl="/posts" />
  </main>
</BaseLayout>
